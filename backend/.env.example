# Port the API listens on (nginx proxies to this)
PORT=3001

# Comma-separated list of allowed CORS origins.
# In production with nginx same-origin proxying this can usually be left unset,
# but set it to your public domain if you ever call the API directly.
# CORS_ORIGIN=https://yourdomain.com

# Absolute path where audio uploads are stored.
# Defaults to <repo>/backend/uploads — override to keep data outside the repo.
# UPLOADS_DIR=/var/data/jammy/uploads
